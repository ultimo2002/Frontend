{
  "name": "MooVee",
  "description": "Lijsten en reviews voor het MooVee filmplatform",
  "collections": [
    {
      "name": "userLists",
      "fields": [
        {
          "name": "id",
          "type": "number",
          "required": true
        },
        {
          "name": "userId",
          "type": "string",
          "required": true
        },
        {
          "name": "listId",
          "type": "number",
          "required": true
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "min": 1,
          "max": 100
        }
      ],
      "permissions": {
        "GET": ["user", "admin"],
        "POST": ["user", "admin"],
        "PUT": ["user", "admin"],
        "PATCH": ["user", "admin"],
        "DELETE": ["user", "admin"]
      }
    },
    {
      "name": "lists",
      "fields": [
        {
          "name": "id",
          "type": "number",
          "required": true
        },
        {
          "name": "listId",
          "type": "reference:userLists",
          "required": true
        },
        {
          "name": "tmdbId",
          "type": "number",
          "required": true
        }
      ],
      "permissions": {
        "GET": ["user", "admin"],
        "POST": ["user", "admin"],
        "PUT": ["user", "admin"],
        "PATCH": ["user", "admin"],
        "DELETE": ["user", "admin"]
      }
    },
    {
      "name": "reviews",
      "fields": [
        {
          "name": "id",
          "type": "number",
          "required": true
        },
        {
          "name": "userId",
          "type": "string",
          "required": true
        },
        {
          "name": "tmdbId",
          "type": "number",
          "required": true
        },
        {
          "name": "score",
          "type": "number",
          "required": true,
          "min": 1,
          "max": 5
        },
        {
          "name": "review",
          "type": "string",
          "required": false,
          "max": 1000
        }
      ],
      "permissions": {
        "GET": ["anonymous", "user", "admin"],
        "POST": ["user", "admin"],
        "PUT": ["user", "admin"],
        "PATCH": ["user", "admin"],
        "DELETE": ["user", "admin"]
      }
    }
  ],
